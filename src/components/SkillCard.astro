---
import type { SkillCategory } from "../data/site";

export interface Props {
    category: SkillCategory;
    index: number;
}

const { category, index } = Astro.props;
const delayClass = `reveal-delay-${(index % 6) + 1}`;

// Mock proficiency per category (visual only)
const proficiencyMap: Record<string, number> = {
    Lenguajes: 88,
    Frontend: 85,
    Backend: 80,
    "Bases de Datos": 75,
    "IA & Machine Learning": 82,
    "Matemáticas & Estadística": 90,
    "Data Engineering": 70,
    "DevOps & Cloud": 72,
    Herramientas: 85,
};
const proficiency = proficiencyMap[category.title] ?? 75;
---

<div
    class={`group relative reveal ${delayClass}`}
    style={`transition-delay: ${index * 60}ms`}
>
    <!-- Subtle top accent line on hover -->
    <div
        class="absolute -top-px left-0 right-0 h-px bg-gradient-to-r from-transparent via-zinc-700 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
        aria-hidden="true"
    ></div>

    <div class="pt-6 pb-3">
        <div class="flex items-start justify-between gap-3 mb-4">
            <div class="flex items-center gap-3 min-w-0">
                <span
                    class="text-2xl shrink-0 transition-transform duration-500 group-hover:scale-110 group-hover:rotate-6"
                    aria-hidden="true"
                    >{category.icon}</span
                >
                <div class="min-w-0">
                    <h3
                        class="text-base md:text-lg font-display font-semibold text-zinc-200 group-hover:text-zinc-50 transition-colors tracking-tight"
                    >
                        {category.title}
                    </h3>
                    <p
                        class="text-[10px] font-mono uppercase tracking-[0.2em] text-zinc-600 group-hover:text-zinc-500 transition-colors mt-0.5"
                    >
                        {category.skills.length} tech · {proficiency}%
                    </p>
                </div>
            </div>
        </div>

        <!-- Animated proficiency bar -->
        <div
            class="skill-bar mb-4 opacity-70 group-hover:opacity-100 transition-opacity"
        >
            <div
                class="skill-bar-fill"
                data-fill={proficiency}
                style="width: 0%"
            ></div>
        </div>

        <ul class="flex flex-wrap gap-1.5" role="list">
            {
                category.skills.map((skill) => (
                    <li>
                        <span class="tech-badge">{skill}</span>
                    </li>
                ))
            }
        </ul>
    </div>
</div>
