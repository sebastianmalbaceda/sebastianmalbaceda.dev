---
export interface Props {
    title: string;
    subtitle?: string;
    align?: "left" | "center";
}

const { title, subtitle, align = "center" } = Astro.props;
---

<div
    class={`mb-12 md:mb-16 ${align === "center" ? "text-center" : "text-left"}`}
>
    <h2
        class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-100 relative inline-block
             ${align === 'center' ? 'accent-line' : 'accent-line-left'} pb-3"
    >
        {title}
    </h2>
    {
        subtitle && (
            <p class="mt-6 text-lg text-zinc-500 max-w-2xl mx-auto leading-relaxed">
                {subtitle}
            </p>
        )
    }
</div>
