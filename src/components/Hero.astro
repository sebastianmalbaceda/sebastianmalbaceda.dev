---
import { me, social } from "../data/site";

// Split the headline into segments we can animate word-by-word.
const line1 = "Construyo software con";
const line2 = ["IA", "datos", "y", "producto."];
const accentFor: Record<string, string> = {
  IA: "ember-text italic-accent",
  "datos": "sage-text italic-accent",
  "y": "text-ink-400",
  "producto.": "ember-text italic-accent",
};
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden scroll-mt-16 pt-32 md:pt-28 pb-20" data-tint="ember">
  <div class="absolute inset-0 pointer-events-none parallax" data-parallax="18" aria-hidden="true">
    <div class="absolute top-[10%] left-[5%] w-[480px] h-[480px] rounded-full blur-[120px] opacity-40 animate-breathe" style="background: radial-gradient(circle, rgba(249,115,22,0.5), transparent 70%);"></div>
    <div class="absolute top-[40%] right-[8%] w-[420px] h-[420px] rounded-full blur-[120px] opacity-30 animate-float" style="background: radial-gradient(circle, rgba(251,191,36,0.4), transparent 70%);"></div>
    <div class="absolute bottom-[8%] left-[35%] w-[360px] h-[360px] rounded-full blur-[110px] opacity-20" style="background: radial-gradient(circle, rgba(74,222,128,0.4), transparent 70%);"></div>
  </div>

  <div class="absolute inset-0 pointer-events-none opacity-[0.04]" aria-hidden="true" style="background-image: linear-gradient(rgba(245,245,244,1) 1px, transparent 1px), linear-gradient(90deg, rgba(245,245,244,1) 1px, transparent 1px); background-size: 64px 64px;"></div>

  <div class="shell-wide w-full relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-10 items-center">

      <!-- Left: copy + CTAs -->
      <div class="lg:col-span-8 max-w-5xl">
        <div class="flex flex-wrap items-center justify-between gap-3 mb-10 md:mb-14">
          <div class="reveal inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass border border-sage-500/20 bg-sage-500/5 text-sage-300 font-mono text-xs">
            <span class="relative flex h-2 w-2" aria-hidden="true">
              <span class="absolute inline-flex h-full w-full rounded-full bg-sage-400 opacity-75 animate-ping"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-sage-400"></span>
            </span>
            {me.status}
          </div>
          <div class="hidden md:flex items-center gap-2 text-xs font-mono text-ink-500 reveal d-1">
            <span>{me.location}</span>
            <span class="text-ink-700">·</span>
            <span data-clock>--:--</span>
            <span class="text-ink-700">·</span>
            <span>{new Date().toLocaleDateString("es-ES", { month: "short", year: "numeric" })}</span>
          </div>
        </div>

        <p class="eyebrow mb-7 reveal d-1">{me.role} <span class="text-ink-700">/</span> {me.university}</p>

        <h1 id="hero-headline" class="display text-[clamp(2.6rem,8.5vw,7rem)] text-ink-50 words-target">
          <span class="block">
            {line1.split(" ").map((w) => (
              <span class="word-mask"><span>{w}&nbsp;</span></span>
            ))}
          </span>
          <span class="block">
            {line2.map((w, i) => (
              <span class={`word-mask ${accentFor[w] ?? ""}`}>
                <span style={`transition-delay:${0.5 + i * 0.09}s`}>{w}{i < line2.length - 1 ? "\u00A0" : ""}</span>
              </span>
            ))}
          </span>
        </h1>

        <p class="mt-8 md:mt-10 text-lg md:text-xl text-ink-400 max-w-2xl leading-relaxed reveal d-4">
          {me.tagline}
        </p>

        <div class="mt-10 md:mt-12 flex flex-col sm:flex-row items-stretch sm:items-center gap-3 reveal d-5">
          <a href="#work" class="ripple magnetic btn-ember group elev-ember relative" data-magnetic="0.3" data-ripple="light" data-cursor="Ver trabajo" id="hero-cta">
            Ver trabajo
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" aria-hidden="true"><path d="M7 17 17 7"></path><path d="M7 7h10v10"></path></svg>
            <span class="sparkle-layer pointer-events-none absolute inset-0 overflow-hidden rounded-full" aria-hidden="true"></span>
          </a>
          <a href="#contact" class="ripple btn-ghost" data-cursor="↓">
            <span class="w-1.5 h-1.5 rounded-full bg-sage-400 animate-pulse-soft" aria-hidden="true"></span>
            Hablemos de tu proyecto
          </a>
        </div>

        <div class="mt-12 md:mt-14 flex flex-col md:flex-row items-start md:items-end justify-between gap-6 reveal d-6">
          <ul class="flex items-center gap-1" role="list">
            <li>
              <a href={social.github} target="_blank" rel="noopener noreferrer" class="magnetic inline-flex items-center gap-2 px-3 py-2 rounded-full text-sm text-ink-400 hover:text-ink-50 hover:bg-ink-900/50 transition-all" aria-label="GitHub (se abre en una pestaña nueva)" data-cursor="↗ GitHub" data-magnetic="0.2">
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"></path></svg>
                <span class="hidden sm:inline">GitHub</span>
              </a>
            </li>
            <li>
              <a href={social.linkedin} target="_blank" rel="noopener noreferrer" class="magnetic inline-flex items-center gap-2 px-3 py-2 rounded-full text-sm text-ink-400 hover:text-ink-50 hover:bg-ink-900/50 transition-all" aria-label="LinkedIn (se abre en una pestaña nueva)" data-cursor="↗ LinkedIn" data-magnetic="0.2">
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
                <span class="hidden sm:inline">LinkedIn</span>
              </a>
            </li>
            <li>
              <a href={`mailto:${social.email}`} class="magnetic inline-flex items-center gap-2 px-3 py-2 rounded-full text-sm text-ink-400 hover:text-ink-50 hover:bg-ink-900/50 transition-all" aria-label={`Enviar email a ${social.email}`} data-cursor="Escribir" data-magnetic="0.2">
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
                <span class="hidden sm:inline">Email</span>
              </a>
            </li>
          </ul>

          <div class="flex items-center gap-2 text-xs text-ink-500 font-mono" aria-hidden="true">
            <span>scroll</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="animate-bounce"><path d="M6 9 12 15 18 9"></path></svg>
          </div>
        </div>
      </div>

      <!-- Right: live status panel -->
      <aside class="lg:col-span-4 reveal d-3" aria-label="Panel de estado en vivo">
        <div class="relative rounded-2xl glass-strong p-5 md:p-6 spotlight tilt elev-3" data-tilt="5">
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-ember-500/10 via-transparent to-sage-500/10 pointer-events-none" aria-hidden="true"></div>

          <div class="relative flex items-center justify-between mb-5">
            <span class="inline-flex items-center gap-2 text-[10px] font-mono uppercase tracking-[0.22em] text-ink-500">
              <span class="relative flex h-2 w-2" aria-hidden="true">
                <span class="absolute inline-flex h-full w-full rounded-full bg-sage-400 opacity-75 animate-ping"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-sage-400"></span>
              </span>
              live · systems
            </span>
            <span class="eq" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></span>
          </div>

          <div class="relative grid grid-cols-2 gap-px bg-ink-800/40 rounded-xl overflow-hidden border border-ink-800/60">
            <div class="bg-ink-950/70 p-4">
              <p class="text-[10px] font-mono uppercase tracking-wider text-ink-500 mb-1">Hora local</p>
              <p class="text-3xl font-display text-ink-50 tabular-nums tracking-tight" data-clock>--:--</p>
              <p class="text-[10px] text-ink-600 mt-1 font-mono">Barcelona · CET</p>
            </div>
            <div class="bg-ink-950/70 p-4">
              <p class="text-[10px] font-mono uppercase tracking-wider text-ink-500 mb-1">Estado</p>
              <p class="text-sm font-display text-sage-300 leading-tight mt-1">Disponible</p>
              <p class="text-[10px] text-ink-600 mt-1 font-mono">prácticas · freelance</p>
            </div>
          </div>

          <div class="relative mt-4 rounded-xl border border-ink-800/60 bg-ink-950/70 p-4">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-[10px] font-mono uppercase tracking-wider text-ink-500 mb-1">Foco actual</p>
                <p class="text-sm text-ink-100 font-display leading-snug">LLMs, RAG y agentes autónomos</p>
                <p class="text-[11px] text-ink-500 mt-1.5 font-mono">build · research · ship</p>
              </div>
              <div class="orbit-ring w-16 h-16 shrink-0" aria-hidden="true">
                <span class="orbit-dot"></span>
              </div>
            </div>
          </div>

          <div class="relative mt-4 grid grid-cols-3 gap-2">
            <div class="rounded-lg border border-ink-800/60 bg-ink-950/70 p-3 text-center">
              <p class="text-xl font-display ember-text tabular-nums" data-count={me.stats.projects}>0</p>
              <p class="text-[9px] font-mono uppercase tracking-wider text-ink-600 mt-0.5">proyectos</p>
            </div>
            <div class="rounded-lg border border-ink-800/60 bg-ink-950/70 p-3 text-center">
              <p class="text-xl font-display sage-text tabular-nums" data-count={me.stats.technologies}>0</p>
              <p class="text-[9px] font-mono uppercase tracking-wider text-ink-600 mt-0.5">stack</p>
            </div>
            <div class="rounded-lg border border-ink-800/60 bg-ink-950/70 p-3 text-center">
              <p class="text-xl font-display text-ink-100 tabular-nums">{me.stats.yearStarted}</p>
              <p class="text-[9px] font-mono uppercase tracking-wider text-ink-600 mt-0.5">desde</p>
            </div>
          </div>
        </div>
      </aside>

    </div>
  </div>
</section>
