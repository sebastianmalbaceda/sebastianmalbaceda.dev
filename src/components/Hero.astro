---
import { socialLinks } from "../data/site";
---

<section
    id="hero"
    class="relative min-h-screen flex items-center overflow-hidden"
>
    <!-- Background gradient -->
    <div class="absolute inset-0 pointer-events-none">
        <div
            class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary-500/10 rounded-full blur-[120px]"
        >
        </div>
        <div
            class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-primary-700/5 rounded-full blur-[100px]"
        >
        </div>
    </div>

    <div class="section-container relative z-10 w-full pt-20">
        <div class="max-w-4xl mx-auto text-center">
            <!-- Avatar -->
            <div class="mb-8 inline-block">
                <div class="relative">
                    <img
                        src="/images/sebastianmalbaceda-real.png"
                        alt="Foto de Sebastián Malbaceda Leyva"
                        class="w-24 h-24 md:w-28 md:h-28 rounded-full object-cover border-2 border-zinc-700/50 ring-2 ring-primary-500/20"
                        width="112"
                        height="112"
                        loading="eager"
                    />
                    <div
                        class="absolute -bottom-1 -right-1 w-6 h-6 bg-emerald-500 rounded-full border-2 border-zinc-950 flex items-center justify-center"
                    >
                        <span class="text-xs text-white">✓</span>
                    </div>
                </div>
            </div>

            <!-- Title -->
            <p
                class="text-sm md:text-base font-medium text-primary-400 mb-4 tracking-wider uppercase"
            >
                Estudiante de Ingeniería Informática
            </p>

            <!-- Name -->
            <h1
                class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-zinc-100 leading-tight"
            >
                Sebastián
                <span class="gradient-text">Malbaceda</span>
                <span
                    class="block text-2xl sm:text-3xl md:text-4xl mt-2 text-zinc-500 font-normal"
                    >Leyva</span
                >
            </h1>

            <!-- Description -->
            <p
                class="mt-6 text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto leading-relaxed"
            >
                Apasionado por la inteligencia artificial, el desarrollo de
                software y la resolución de problemas complejos. Creando
                soluciones que combinan análisis de datos, programación y diseño
                de sistemas.
            </p>

            <!-- Code snippet -->
            <div class="mt-8 max-w-lg mx-auto">
                <div class="terminal-snippet text-left">
                    <span class="text-primary-400">class</span>
                    <span class="text-emerald-400">SebastianMalbaceda</span>
                    {"{"}
                    <br />
                    <span class="text-zinc-600 ml-4"
                        >// Computer Science Engineer</span
                    >
                    <br />
                    <span class="ml-4 text-zinc-400">focus:</span>
                    <span class="text-amber-300">'AI'</span>, <span
                        class="text-amber-300">'ML'</span
                    >, <span class="text-amber-300">'CV'</span>;
                    <br />
                    <span class="ml-4 text-zinc-400">status:</span>
                    <span class="text-emerald-400">'building'</span>;
                    <br />
                    {"}"}
                </div>
            </div>

            <!-- CTA Buttons -->
            <div
                class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4"
            >
                <a
                    href="#projects"
                    class="inline-flex items-center gap-2 px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white rounded-xl font-medium transition-all duration-200 shadow-lg shadow-primary-600/25 hover:shadow-primary-500/40"
                >
                    Ver proyectos
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="M7 7h10v10"></path><path d="M7 17 17 7"
                        ></path></svg
                    >
                </a>
                <a
                    href="#contact"
                    class="inline-flex items-center gap-2 px-6 py-3 border border-zinc-700 hover:border-zinc-500 text-zinc-300 rounded-xl font-medium transition-all duration-200"
                >
                    Contactar
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="M22 12h-6l-2 3-4-9-2 3H2"></path></svg
                    >
                </a>
            </div>

            <!-- Social links -->
            <div class="mt-10 flex items-center justify-center gap-6">
                <a
                    href={socialLinks.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-zinc-500 hover:text-zinc-300 transition-colors"
                    aria-label="GitHub"
                >
                    <svg
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                        width="22"
                        height="22"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        ><path
                            d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                        ></path></svg
                    >
                </a>
                <a
                    href={socialLinks.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-zinc-500 hover:text-zinc-300 transition-colors"
                    aria-label="LinkedIn"
                >
                    <svg
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                        width="22"
                        height="22"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        ><path
                            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                        ></path></svg
                    >
                </a>
                <a
                    href={`mailto:${socialLinks.email}`}
                    class="text-zinc-500 hover:text-zinc-300 transition-colors"
                    aria-label="Email"
                >
                    <svg
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                        width="22"
                        height="22"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><rect width="20" height="16" x="2" y="4" rx="2"
                        ></rect><path
                            d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
                        ></path></svg
                    >
                </a>
            </div>
        </div>

        <!-- Scroll indicator -->
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-zinc-600"><path d="M6 9 12 15 18 9"></path></svg
            >
        </div>
    </div>
</section>
