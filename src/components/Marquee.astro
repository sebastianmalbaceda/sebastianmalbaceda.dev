---
export interface Props {
  items: string[];
  class?: string;
}
const { items, class: className = "" } = Astro.props;
// Duplicate the list so the track can loop seamlessly (translate -50%)
const seq = [...items, ...items];
---

<div class={`tech-carousel ${className}`} role="region" aria-label="Tecnologías">
  <div class="tech-carousel-track">
    {seq.map((item, i) => (
      <div class="tech-carousel-item" aria-hidden={i >= items.length ? "true" : undefined}>
        <span class="font-display text-2xl md:text-3xl font-medium text-ink-400 hover:text-ink-100 transition-colors whitespace-nowrap">{item}</span>
        <span class="text-ember-500/70 select-none" aria-hidden="true">✦</span>
      </div>
    ))}
  </div>
  <!-- Edge fades -->
  <div class="tech-carousel-fade tech-carousel-fade-left" aria-hidden="true"></div>
  <div class="tech-carousel-fade tech-carousel-fade-right" aria-hidden="true"></div>
</div>

<style>
  .tech-carousel {
    position: relative;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }
  .tech-carousel-track {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    width: max-content;
    animation: carousel-roll 50s linear infinite;
  }
  .tech-carousel:hover .tech-carousel-track {
    animation-play-state: paused;
  }
  .tech-carousel-item {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-shrink: 0;
  }
  @keyframes carousel-roll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .tech-carousel-track { animation: none; }
    .tech-carousel-track {
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      gap: 1rem;
    }
  }
</style>
