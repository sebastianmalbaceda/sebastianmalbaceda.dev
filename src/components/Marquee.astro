---
export interface Props {
  items: string[];
  class?: string;
}
const { items, class: className = "" } = Astro.props;
// Duplicate the list so the track can loop seamlessly (translate -50%)
const seq = [...items, ...items];
---

<div class={`tech-carousel ${className}`} role="region" aria-label="Tecnologías que manejo">
  <div class="tech-carousel-track">
    {seq.map((item, i) => (
      <div class="tech-carousel-item" aria-hidden={i >= items.length ? "true" : undefined}>
        <span class="font-display text-2xl md:text-3xl font-medium whitespace-nowrap">{item}</span>
        <span class="tech-carousel-sep" aria-hidden="true">✦</span>
      </div>
    ))}
  </div>
</div>

<style>
  .tech-carousel {
    position: relative;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }
  .tech-carousel-track {
    display: flex;
    align-items: center;
    gap: 2.75rem;
    width: max-content;
    animation: carousel-roll 65s linear infinite;
  }
  .tech-carousel:hover .tech-carousel-track {
    animation-play-state: paused;
  }
  .tech-carousel-item {
    display: flex;
    align-items: center;
    gap: 2.75rem;
    flex-shrink: 0;
  }
  .tech-carousel-item span:first-child {
    color: #d6d3d1; /* ink-300 */
    transition: color .25s ease;
  }
  .tech-carousel-item:hover span:first-child {
    color: #fafaf9; /* ink-50 */
  }
  .tech-carousel-sep {
    color: rgba(249, 115, 22, 0.65);
    font-size: 0.9rem;
    user-select: none;
  }
  @keyframes carousel-roll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .tech-carousel-track { animation: none; }
    .tech-carousel-track {
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      gap: 1rem;
    }
    .tech-carousel-item { gap: 1rem; }
  }
</style>
