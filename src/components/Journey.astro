---
import { journey } from "../data/site";

const kindLabel: Record<string, string> = {
  education: "educación",
  project: "proyecto",
  milestone: "hito",
};
---

<section id="journey" class="section relative" data-tint="coral">
  <div class="shell-wide">
    <div class="mb-14 md:mb-16">
      <p class="eyebrow mb-6 reveal">04 — Trayectoria</p>
      <h2 class="display text-4xl sm:text-5xl md:text-6xl text-ink-50 max-w-2xl reveal d-1">
        El camino hasta <span class="italic-accent ember-text">ahora</span>.
      </h2>
    </div>

    <ol class="max-w-3xl" role="list">
      {journey.map((j, i) => {
        const delayClass = `d-${(i % 6) + 1}`;
        const isNow = j.year.toLowerCase() === "ahora";
        return (
        <li class={`reveal ${delayClass}`} style={`transition-delay: ${i * 70}ms`}>
          <div class="grid grid-cols-[4.5rem_1fr] sm:grid-cols-[6rem_1fr] gap-x-5 sm:gap-x-8 pb-10 last:pb-0">
            <!-- Year column -->
            <div class="pt-1 text-right sm:text-left">
              <span class={`font-display text-xl sm:text-2xl tabular-nums tracking-tight ${isNow ? "text-sage-300" : "text-ink-200"}`}>{j.year}</span>
            </div>

            <!-- Timeline + content -->
            <div class="relative pl-7 sm:pl-9 border-l border-ink-800/70">
              <span class={`absolute left-0 top-1.5 -translate-x-1/2 w-[15px] h-[15px] rounded-full border-2 ${isNow ? "border-sage-500 bg-sage-500/30" : "border-ember-500/60"} bg-ink-950 flex items-center justify-center`} aria-hidden="true">
                <span class={`w-1.5 h-1.5 rounded-full ${isNow ? "bg-sage-400" : "bg-ember-400"}`}></span>
                {isNow && <span class="absolute inset-0 rounded-full bg-sage-400/40 animate-ping" aria-hidden="true"></span>}
              </span>

              <div class="mb-1.5 flex items-center gap-2">
                <span class="text-[10px] font-mono uppercase tracking-[0.22em] text-ink-600">{kindLabel[j.kind]}</span>
              </div>
              <h3 class="font-display text-xl md:text-2xl text-ink-50 tracking-tight leading-snug">{j.title}</h3>
              <p class="text-sm text-ink-500 font-mono mt-1">{j.place}</p>
              <p class="text-ink-400 leading-relaxed mt-2.5 max-w-xl">{j.description}</p>
            </div>
          </div>
        </li>
        );
      })}
    </ol>
  </div>
</section>
