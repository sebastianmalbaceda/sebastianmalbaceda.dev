<div
  id="scroll-progress"
  class="fixed top-0 left-0 right-0 h-[2px] z-[60] pointer-events-none origin-left scale-x-0 bg-gradient-to-r from-ember-500 via-gold-400 to-coral transition-transform duration-150"
  role="progressbar"
  aria-label="Progreso de lectura"
  aria-valuemin="0"
  aria-valuemax="100"
  aria-valuenow="0"
></div>

<button
  id="back-to-top"
  type="button"
  class="fixed bottom-6 right-6 z-50 w-11 h-11 rounded-full glass-strong flex items-center justify-center text-ink-400 hover:text-ink-50 transition-all duration-300 opacity-0 translate-y-4 pointer-events-none elev-2"
  data-cursor="↑"
  aria-label="Volver arriba"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 19V5"></path>
    <path d="m5 12 7-7 7 7"></path>
  </svg>
</button>
