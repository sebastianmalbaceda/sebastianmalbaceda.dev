---
import { me } from "../data/site";
---

<section id="manifesto" class="relative py-24 md:py-36 overflow-hidden" data-tint="gold" aria-label="Manifesto">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[680px] h-[680px] rounded-full blur-[140px] opacity-25" style="background: radial-gradient(circle, rgba(251,191,36,0.45), transparent 70%);"></div>
  </div>

  <div class="shell-wide relative">
    <div class="max-w-4xl">
      <p class="eyebrow mb-8 reveal">
        <span class="ember-text font-semibold">/* manifesto */</span>
        <span class="text-ink-700" aria-hidden="true">—</span>
        <span>principios</span>
      </p>

      <blockquote class="display text-[clamp(1.6rem,4.2vw,3.5rem)] text-ink-100 leading-[1.18] tracking-tight reveal d-1">
        <span class="text-ember-500/70 select-none align-top" aria-hidden="true">“</span>No construyo demos: construyo
        <span class="italic-accent ember-text swipe-underline swipe-ember">sistemas</span>
        que se usan, se mantienen y
        <span class="italic-accent sage-text swipe-underline swipe-sage">mejoran</span>
        con el tiempo — desde el modelo hasta el píxel, con rigor y
        <span class="italic-accent ember-text swipe-underline swipe-ember">cuidado</span><span class="text-ember-500/70 select-none align-top" aria-hidden="true">”</span>.
      </blockquote>

      <div class="mt-10 flex items-center gap-4 reveal d-2">
        <span class="h-px w-12 bg-gradient-to-r from-ember-500 to-transparent" aria-hidden="true"></span>
        <p class="font-mono text-xs uppercase tracking-[0.22em] text-ink-500">
          {me.shortName} · {me.role}
        </p>
      </div>
    </div>
  </div>
</section>
