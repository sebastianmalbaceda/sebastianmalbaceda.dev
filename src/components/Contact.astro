---
import { social } from "../data/site";
---

<section id="contact" class="section relative" data-tint="ember">
  <div class="shell-wide">
    <div class="max-w-3xl mx-auto text-center mb-14">
      <p class="eyebrow justify-center mb-6 reveal" style="justify-content:center">07 — Contacto</p>
      <h2 class="display text-4xl sm:text-5xl md:text-6xl text-ink-50 reveal d-1">
        ¿Construimos <span class="italic-accent ember-text">algo</span> juntos?
      </h2>
      <p class="mt-5 text-ink-400 max-w-md mx-auto leading-relaxed reveal d-2">
        Abierto a prácticas, colaboraciones y proyectos. Cuéntame tu idea — leo cada mensaje.
      </p>
    </div>

    <div class="max-w-2xl mx-auto">
      <!-- CTA card -->
      <div class="relative overflow-hidden rounded-3xl p-8 md:p-12 text-center reveal spotlight tilt elev-3" data-tilt="3">
        <div class="absolute inset-0 bg-gradient-to-br from-ember-500/10 via-gold-500/5 to-sage-500/10" aria-hidden="true"></div>
        <div class="absolute inset-px rounded-3xl bg-ink-950/80 backdrop-blur-xl" aria-hidden="true"></div>
        <div class="relative">
          <div class="flex justify-center mb-5">
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass border border-sage-500/20 bg-sage-500/5 text-sage-300 font-mono text-xs">
              <span class="relative flex h-2 w-2" aria-hidden="true">
                <span class="absolute inline-flex h-full w-full rounded-full bg-sage-400 opacity-75 animate-ping"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-sage-400"></span>
              </span>
              Respondiendo en 24h
            </span>
          </div>
          <h3 class="text-2xl md:text-3xl font-display text-ink-50 mb-3 tracking-tight">Mi inbox siempre está abierto</h3>
          <p class="text-ink-400 max-w-md mx-auto">Ya sea una idea, un proyecto o simplemente un saludo.</p>
          <a href={`mailto:${social.email}`} class="ripple magnetic group mt-7 inline-flex items-center gap-2 px-6 py-3 bg-ink-50 text-ink-950 hover:bg-white rounded-full font-medium transition-all duration-300 elev-1" data-magnetic="0.3" data-ripple="light">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
            <span class="font-mono text-sm md:text-base break-all">{social.email}</span>
          </a>
        </div>
      </div>

      <!-- Form -->
      <form id="contact-form" action={`mailto:${social.email}`} method="POST" enctype="text/plain" novalidate class="mt-8 p-6 md:p-8 rounded-2xl border border-ink-800/70 bg-ink-900/30 space-y-5 reveal d-1">
        <div class="absolute -left-[9999px]" aria-hidden="true">
          <label for="company-website">No rellenar</label>
          <input type="text" id="company-website" name="company-website" tabindex="-1" autocomplete="off" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-[10px] font-mono uppercase tracking-[0.2em] text-ink-500 mb-2">Nombre</label>
            <input type="text" id="name" name="name" required placeholder="Tu nombre" autocomplete="name" maxlength="100" class="w-full px-3 py-2.5 bg-ink-950/50 border border-ink-800 rounded-lg text-ink-50 placeholder-ink-600 focus:outline-none focus:border-ember-500/60 focus:bg-ink-950 transition-colors" />
          </div>
          <div>
            <label for="email" class="block text-[10px] font-mono uppercase tracking-[0.2em] text-ink-500 mb-2">Email</label>
            <input type="email" id="email" name="email" required placeholder="tu@email.com" autocomplete="email" maxlength="120" class="w-full px-3 py-2.5 bg-ink-950/50 border border-ink-800 rounded-lg text-ink-50 placeholder-ink-600 focus:outline-none focus:border-ember-500/60 focus:bg-ink-950 transition-colors" />
          </div>
        </div>
        <div>
          <label for="message" class="block text-[10px] font-mono uppercase tracking-[0.2em] text-ink-500 mb-2">Mensaje</label>
          <textarea id="message" name="message" rows="4" required placeholder="Cuéntame..." maxlength="2000" class="w-full px-3 py-2.5 bg-ink-950/50 border border-ink-800 rounded-lg text-ink-50 placeholder-ink-600 focus:outline-none focus:border-ember-500/60 focus:bg-ink-950 transition-colors resize-none"></textarea>
        </div>
        <p id="contact-feedback" role="status" aria-live="polite" class="hidden text-sm rounded-lg px-4 py-3"></p>
        <button type="submit" class="ripple magnetic w-full py-3.5 bg-ink-50 hover:bg-white text-ink-950 rounded-full font-medium transition-all duration-300 inline-flex items-center justify-center gap-2 group elev-1" data-magnetic="0.2" data-ripple="light">
          Enviar mensaje
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </button>
      </form>

      <ul class="mt-6 flex flex-wrap justify-center gap-2" role="list">
        <li>
          <a href={social.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-ink-800/70 hover:border-ink-700 text-sm text-ink-400 hover:text-ink-50 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"></path></svg>
            GitHub
          </a>
        </li>
        <li>
          <a href={social.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-ink-800/70 hover:border-ink-700 text-sm text-ink-400 hover:text-ink-50 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
            LinkedIn
          </a>
        </li>
      </ul>
    </div>
  </div>
</section>
