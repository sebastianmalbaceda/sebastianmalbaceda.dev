---
export interface Props {
    index: string;
    label: string;
    title: string;
    description?: string;
    align?: "left" | "center";
}

const { index, label, title, description, align = "left" } = Astro.props;
---

<header
    class={`mb-12 md:mb-16 ${align === "center" ? "text-center" : ""}`}
>
    <div
        class={`flex items-end gap-4 mb-5 reveal ${align === "center" ? "justify-center" : ""}`}
    >
        <span
            class="font-mono text-6xl sm:text-7xl md:text-8xl font-bold leading-[0.85] gradient-text-static opacity-30 select-none tabular-nums"
            aria-hidden="true"
        >
            {index}
        </span>
        <span
            class="font-mono text-[10px] sm:text-xs uppercase tracking-[0.3em] text-zinc-500 pb-2 sm:pb-3"
        >
            {label}
        </span>
    </div>
    <h2
        class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-display font-bold tracking-[-0.03em] text-zinc-100 max-w-3xl reveal reveal-delay-1"
        class:list={[{ "mx-auto": align === "center" }]}
    >
        {title}
    </h2>
    {
        description && (
            <p
                class="mt-4 md:mt-5 text-base md:text-lg text-zinc-400 leading-relaxed max-w-2xl reveal reveal-delay-2"
                class:list={[{ "mx-auto": align === "center" }]}
            >
                {description}
            </p>
        )
    }
</header>
