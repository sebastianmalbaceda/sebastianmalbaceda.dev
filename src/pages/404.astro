---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Interactions from "../components/Interactions.astro";
---

<BaseLayout
    title="404 — Página no encontrada | Sebastián Malbaceda Leyva"
    description="La página que buscas no existe o ha sido movida."
>
    <Interactions />
    <Navbar />

    <main
        id="main"
        class="min-h-screen flex items-center justify-center pt-32 pb-16 px-4 relative overflow-hidden"
    >
        <div
            class="absolute inset-0 pointer-events-none"
            aria-hidden="true"
        >
            <div
                class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full blur-[120px] opacity-30"
                style="background: radial-gradient(circle, rgba(244,63,94,0.4), transparent 60%);"
            ></div>
        </div>

        <div class="max-w-xl mx-auto text-center relative">
            <div
                class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass border border-zinc-800/50 mb-8 font-mono text-xs text-zinc-500 reveal"
            >
                <span class="w-1.5 h-1.5 rounded-full bg-rose-400"></span>
                <span>error / "404" / "not_found"</span>
            </div>

            <p
                class="text-9xl md:text-[12rem] font-display font-bold gradient-text leading-none reveal reveal-delay-1"
                aria-hidden="true"
            >
                404
            </p>
            <h1
                class="mt-6 text-2xl md:text-3xl font-display font-bold text-zinc-100 reveal reveal-delay-2"
            >
                Página no encontrada
            </h1>
            <p
                class="mt-4 text-zinc-400 leading-relaxed reveal reveal-delay-3"
            >
                La ruta solicitada no existe, ha sido movida o el enlace está
                roto. Vuelve al inicio o explora otras secciones.
            </p>
            <div
                class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3 reveal reveal-delay-4"
            >
                <a
                    href="/"
                    class="magnetic inline-flex items-center gap-2 px-6 py-3 bg-zinc-100 text-zinc-900 hover:bg-white rounded-full font-medium transition-all duration-300"
                    data-magnetic="0.3"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path d="m12 19-7-7 7-7"></path>
                        <path d="M19 12H5"></path>
                    </svg>
                    Volver al inicio
                </a>
                <a
                    href="/blog"
                    class="inline-flex items-center gap-2 px-6 py-3 border border-zinc-700 hover:border-zinc-500 text-zinc-300 rounded-full font-medium transition-all duration-300"
                >
                    Ver el blog
                </a>
            </div>
        </div>
    </main>

    <Footer />
</BaseLayout>
