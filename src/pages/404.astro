---
import BaseLayout from "../layouts/BaseLayout.astro";
import Effects from "../components/Effects.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="404 — Página no encontrada | Sebastián Malbaceda Leyva" description="La página que buscas no existe o ha sido movida.">
  <Effects />
  <Nav />

  <main id="main" class="min-h-screen flex items-center justify-center pt-32 pb-16 px-4 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full blur-[120px] opacity-30" style="background: radial-gradient(circle, rgba(249,115,22,0.4), transparent 60%);"></div>
    </div>

    <div class="max-w-xl mx-auto text-center relative">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass border border-ink-800/60 mb-8 font-mono text-xs text-ink-500 reveal">
        <span class="w-1.5 h-1.5 rounded-full bg-coral"></span>
        <span>error / "404" / "not_found"</span>
      </div>

      <p class="display text-[8rem] md:text-[12rem] ember-text leading-none reveal d-1" aria-hidden="true">404</p>
      <h1 class="mt-6 text-2xl md:text-3xl font-display text-ink-50 reveal d-2">Página no encontrada</h1>
      <p class="mt-4 text-ink-400 leading-relaxed reveal d-3">La ruta solicitada no existe, ha sido movida o el enlace está roto. Vuelve al inicio o explora otras secciones.</p>

      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3 reveal d-4">
        <a href="/" class="ripple magnetic inline-flex items-center gap-2 px-6 py-3 bg-ink-50 text-ink-950 hover:bg-white rounded-full font-medium transition-all duration-300 elev-1" data-magnetic="0.3" data-ripple="light">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
          Volver al inicio
        </a>
        <a href="/blog" class="ripple inline-flex items-center gap-2 px-6 py-3 border border-ink-700 hover:border-ink-500 text-ink-100 rounded-full font-medium transition-all duration-300">Ver el blog</a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
