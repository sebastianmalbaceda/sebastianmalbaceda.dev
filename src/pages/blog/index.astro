---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Effects from "../../components/Effects.astro";
import ScrollProgress from "../../components/ScrollProgress.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const categories = [...new Set(posts.map((p) => p.data.category))];
---

<BaseLayout title="Escritos | Sebastián Malbaceda Leyva" description="Artículos sobre inteligencia artificial, desarrollo de software, visión por computador y tecnología.">
  <Effects />
  <ScrollProgress />
  <Nav currentPath="/blog" />

  <main id="main" class="pt-32 section min-h-screen">
    <div class="shell-wide">
      <p class="eyebrow mb-6 reveal">// — Escritos</p>
      <h1 class="display text-4xl sm:text-5xl md:text-6xl text-ink-50 max-w-2xl reveal d-1">
        Notas y <span class="italic-accent ember-text">aprendizajes</span>.
      </h1>
      <p class="mt-5 text-ink-400 max-w-xl leading-relaxed reveal d-2">
        Reflexiones, tutoriales y aprendizajes sobre tecnología, programación e inteligencia artificial.
      </p>

      <div class="flex flex-wrap justify-center gap-2 mb-14 mt-12 reveal d-3" id="blog-categories" role="group" aria-label="Filtrar artículos por categoría">
        <button type="button" data-category="all" class="px-4 py-2 text-sm rounded-full bg-ember-500/10 text-ember-300 border border-ember-500/30 font-mono" aria-pressed="true">#all</button>
        {categories.map((cat) => (
          <button type="button" data-category={cat} class="px-4 py-2 text-sm rounded-full bg-ink-900/60 text-ink-400 border border-ink-800 hover:bg-ink-800 transition-colors font-mono" aria-pressed="false">#{cat}</button>
        ))}
      </div>

      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12" id="blog-posts">
          {posts.map((post, i) => (
            <div data-category={post.data.category}>
              <BlogCard post={post} index={i} />
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <p class="text-ink-500 text-lg">No hay artículos publicados todavía.</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  function setupCategoryFilter() {
    const buttons = document.querySelectorAll<HTMLButtonElement>("#blog-categories button[data-category]");
    const posts = document.querySelectorAll<HTMLElement>("#blog-posts [data-category]");
    if (!buttons.length) return;
    const filter = (cat: string) => {
      buttons.forEach((b) => {
        const on = b.dataset.category === cat;
        b.className = on
          ? "px-4 py-2 text-sm rounded-full bg-ember-500/10 text-ember-300 border border-ember-500/30 font-mono"
          : "px-4 py-2 text-sm rounded-full bg-ink-900/60 text-ink-400 border border-ink-800 hover:bg-ink-800 transition-colors font-mono";
        b.setAttribute("aria-pressed", String(on));
      });
      posts.forEach((p) => { p.style.display = cat === "all" || p.dataset.category === cat ? "" : "none"; });
    };
    const params = new URLSearchParams(window.location.search);
    filter(params.get("category") || "all");
    buttons.forEach((b) => {
      if (b.dataset.bfBound === "1") return;
      b.dataset.bfBound = "1";
      b.addEventListener("click", () => {
        const cat = b.dataset.category || "all";
        const url = new URL(window.location.href);
        if (cat === "all") url.searchParams.delete("category"); else url.searchParams.set("category", cat);
        window.history.pushState({}, "", url);
        filter(cat);
      });
    });
    window.addEventListener("popstate", () => filter(new URLSearchParams(window.location.search).get("category") || "all"), { once: true });
  }
  // `astro:page-load` fires on the initial load and after every view transition.
  document.addEventListener("astro:page-load", () => {
    if (document.getElementById("blog-categories")) setupCategoryFilter();
  });
</script>
