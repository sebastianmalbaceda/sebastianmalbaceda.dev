---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import SectionTitle from "../components/SectionTitle.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SkillCard from "../components/SkillCard.astro";
import BlogCard from "../components/BlogCard.astro";
import { projects, skillCategories, socialLinks } from "../data/site";
import { getCollection } from "astro:content";

const blogPosts = await getCollection("blog", ({ data }) => !data.draft);
const latestPosts = blogPosts
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
    .slice(0, 3);
---

<BaseLayout
    title="Sebastián Malbaceda Leyva | Estudiante de Ingeniería Informática"
    description="Estudiante de Ingeniería Informática apasionado por la inteligencia artificial, el desarrollo de software y la creación de soluciones tecnológicas innovadoras."
>
    <Navbar />

    <main>
        <!-- Hero Section -->
        <Hero />

        <!-- About Section -->
        <section id="about" class="section-padding relative reveal">
            <div class="absolute inset-0 pointer-events-none">
                <div
                    class="absolute top-0 left-0 w-[400px] h-[400px] bg-primary-500/5 rounded-full blur-[100px]"
                >
                </div>
            </div>
            <div class="section-container relative">
                <SectionTitle
                    title="Sobre mí"
                    subtitle="Estudiante de Ingeniería Informática con mención en Computación en la Universitat Autònoma de Barcelona."
                />

                <div
                    class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-center"
                >
                    <!-- Photo -->
                    <div class="lg:col-span-2 flex justify-center">
                        <div class="relative">
                            <img
                                src="/images/sebastianmalbaceda-github.jpg"
                                alt="Sebastián Malbaceda - Avatar"
                                class="w-56 h-56 md:w-64 md:h-64 rounded-2xl object-cover border border-zinc-800/50 shadow-xl"
                                loading="lazy"
                            />
                            <div
                                class="absolute -bottom-3 -right-3 glass rounded-xl px-4 py-2"
                            >
                                <span
                                    class="text-sm font-medium text-primary-400"
                                    >UAB</span
                                >
                            </div>
                        </div>
                    </div>

                    <!-- Bio -->
                    <div class="lg:col-span-3 space-y-5">
                        <p class="text-lg text-zinc-300 leading-relaxed">
                            Soy estudiante de <strong class="text-zinc-100"
                                >Ingeniería Informática</strong
                            > en la
                            <strong class="text-zinc-100"
                                >Universitat Autònoma de Barcelona</strong
                            >, apasionado por la
                            <strong class="text-zinc-100"
                                >inteligencia artificial</strong
                            >, el desarrollo de software y la resolución de
                            problemas complejos.
                        </p>
                        <p class="text-zinc-400 leading-relaxed">
                            Mi enfoque se centra en la creación de soluciones
                            innovadoras que combinan análisis de datos,
                            programación y diseño de sistemas. He desarrollado
                            proyectos en áreas como
                            <strong class="text-zinc-300">
                                visión por computador</strong
                            >,
                            <strong class="text-zinc-300">
                                machine learning</strong
                            >,
                            <strong class="text-zinc-300"> robótica</strong> y
                            <strong class="text-zinc-300">
                                videojuegos educativos</strong
                            >.
                        </p>
                        <p class="text-zinc-400 leading-relaxed">
                            Creo firmemente en el <strong class="text-zinc-300"
                                >aprendizaje continuo</strong
                            > y en el poder de la tecnología para generar un impacto
                            positivo en la sociedad. Actualmente exploro el desarrollo
                            web moderno con Astro y Tailwind CSS, mientras profundizo
                            en técnicas avanzadas de deep learning.
                        </p>

                        <!-- Highlights -->
                        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 pt-4">
                            <div class="glass rounded-lg p-4 text-center">
                                <span class="text-2xl font-bold gradient-text"
                                    >+8</span
                                >
                                <p class="text-xs text-zinc-500 mt-1">
                                    Proyectos
                                </p>
                            </div>
                            <div class="glass rounded-lg p-4 text-center">
                                <span class="text-2xl font-bold gradient-text"
                                    >+30</span
                                >
                                <p class="text-xs text-zinc-500 mt-1">
                                    Tecnologías
                                </p>
                            </div>
                            <div class="glass rounded-lg p-4 text-center">
                                <span class="text-2xl font-bold gradient-text"
                                    >2022</span
                                >
                                <p class="text-xs text-zinc-500 mt-1">
                                    Inicio UAB
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Projects Section -->
        <section
            id="projects"
            class="section-padding relative bg-zinc-950/50 reveal"
        >
            <div class="section-container">
                <SectionTitle
                    title="Proyectos destacados"
                    subtitle="Una selección de los proyectos que he desarrollado, combinando IA, robótica, visión por computador y desarrollo web."
                />

                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 auto-rows-fr"
                >
                    {
                        projects
                            .filter((p) => p.featured)
                            .map((project, i) => (
                                <ProjectCard
                                    project={project}
                                    index={i}
                                    large={i === 0 || i === 3 || i === 4}
                                />
                            ))
                    }
                </div>
            </div>
        </section>

        <!-- Skills Section -->
        <section id="skills" class="section-padding relative reveal">
            <div class="section-container">
                <SectionTitle
                    title="Habilidades técnicas"
                    subtitle="Tecnologías y herramientas con las que trabajo."
                />

                <div
                    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"
                >
                    {
                        skillCategories.map((category, i) => (
                            <SkillCard category={category} index={i} />
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- Blog Section -->
        <section
            id="blog"
            class="section-padding relative bg-zinc-950/50 reveal"
        >
            <div class="section-container">
                <SectionTitle
                    title="Últimos artículos"
                    subtitle="Reflexiones y aprendizajes sobre tecnología, programación e inteligencia artificial."
                />

                {
                    latestPosts.length > 0 ? (
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                            {latestPosts.map((post, i) => (
                                <BlogCard post={post} index={i} />
                            ))}
                        </div>
                    ) : (
                        <div class="text-center py-12">
                            <p class="text-zinc-500">
                                Próximamente nuevos artículos.
                            </p>
                        </div>
                    )
                }

                <div class="mt-10 text-center">
                    <a
                        href="/blog"
                        class="inline-flex items-center gap-2 px-6 py-3 border border-zinc-700 hover:border-zinc-500 text-zinc-300 rounded-xl font-medium transition-all duration-200"
                    >
                        Ver todos los artículos
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                            ></path></svg
                        >
                    </a>
                </div>
            </div>
        </section>

        <!-- Contact Section -->
        <section id="contact" class="section-padding relative reveal">
            <div class="absolute inset-0 pointer-events-none">
                <div
                    class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-primary-500/5 rounded-full blur-[120px]"
                >
                </div>
            </div>
            <div class="section-container relative">
                <SectionTitle
                    title="Contacto"
                    subtitle="Estoy abierto a nuevas oportunidades, colaboraciones y proyectos. No dudes en escribirme."
                />

                <div class="max-w-2xl mx-auto">
                    <!-- Contact form (static - preparado para Formspree/Cloudflare Forms) -->
                    <form
                        action="#"
                        method="POST"
                        class="glass rounded-xl p-6 md:p-8 space-y-6"
                    >
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label
                                    for="name"
                                    class="block text-sm font-medium text-zinc-300 mb-2"
                                    >Nombre</label
                                >
                                <input
                                    type="text"
                                    id="name"
                                    name="name"
                                    placeholder="Tu nombre"
                                    class="w-full px-4 py-2.5 bg-zinc-900/80 border border-zinc-800 rounded-lg text-zinc-100 placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-500/50 transition-colors"
                                />
                            </div>
                            <div>
                                <label
                                    for="email"
                                    class="block text-sm font-medium text-zinc-300 mb-2"
                                    >Email</label
                                >
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    placeholder="tu@email.com"
                                    class="w-full px-4 py-2.5 bg-zinc-900/80 border border-zinc-800 rounded-lg text-zinc-100 placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-500/50 transition-colors"
                                />
                            </div>
                        </div>
                        <div>
                            <label
                                for="message"
                                class="block text-sm font-medium text-zinc-300 mb-2"
                                >Mensaje</label
                            >
                            <textarea
                                id="message"
                                name="message"
                                rows="5"
                                placeholder="Escribe tu mensaje aquí..."
                                class="w-full px-4 py-2.5 bg-zinc-900/80 border border-zinc-800 rounded-lg text-zinc-100 placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-500/50 transition-colors resize-none"
                            ></textarea>
                        </div>
                        <button
                            type="submit"
                            disabled
                            class="w-full py-3 bg-primary-600/50 text-zinc-400 rounded-xl font-medium cursor-not-allowed"
                            title="Formulario desactivado. Contáctame directamente por email."
                        >
                            Formulario disponible próximamente
                        </button>
                        <p class="text-xs text-center text-zinc-600">
                            Mientras tanto, escríbeme directamente a
                            <a
                                href={`mailto:${socialLinks.email}`}
                                class="text-primary-400 hover:text-primary-300 transition-colors"
                            >
                                {socialLinks.email}
                            </a>
                        </p>
                    </form>

                    <!-- Direct contact options -->
                    <div class="mt-8 flex justify-center gap-6">
                        <a
                            href={socialLinks.github}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="glass rounded-xl px-5 py-3 flex items-center gap-3 text-sm text-zinc-300 hover:text-primary-400 transition-all card-hover"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                ><path
                                    d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                                ></path></svg
                            >
                            GitHub
                        </a>
                        <a
                            href={socialLinks.linkedin}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="glass rounded-xl px-5 py-3 flex items-center gap-3 text-sm text-zinc-300 hover:text-primary-400 transition-all card-hover"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                ><path
                                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                                ></path></svg
                            >
                            LinkedIn
                        </a>
                        <a
                            href={`mailto:${socialLinks.email}`}
                            class="glass rounded-xl px-5 py-3 flex items-center gap-3 text-sm text-zinc-300 hover:text-primary-400 transition-all card-hover"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><rect width="20" height="16" x="2" y="4" rx="2"
                                ></rect><path
                                    d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
                                ></path></svg
                            >
                            Email
                        </a>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>

<script>
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("visible");
                }
            });
        },
        { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
    );

    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>
