---
import BaseLayout from "../layouts/BaseLayout.astro";
import Effects from "../components/Effects.astro";
import ScrollProgress from "../components/ScrollProgress.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Marquee from "../components/Marquee.astro";
import Manifesto from "../components/Manifesto.astro";
import About from "../components/About.astro";
import Work from "../components/Work.astro";
import Capabilities from "../components/Capabilities.astro";
import Journey from "../components/Journey.astro";
import Now from "../components/Now.astro";
import Writing from "../components/Writing.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { me, allTechnologies } from "../data/site";
---

<BaseLayout title={`${me.name} | ${me.role}`} description={me.description}>
  <Effects />
  <ScrollProgress />
  <Nav />

  <main id="main">
    <Hero />

    <div class="relative border-y border-ink-800/60 py-8 md:py-10 bg-ink-950/60 overflow-hidden">
      <div class="shell-wide relative mb-5 flex items-center justify-between gap-4">
        <p class="eyebrow">stack · en bucle</p>
        <p class="hidden sm:block font-mono text-[10px] uppercase tracking-[0.22em] text-ink-600">{allTechnologies.length} tecnologías</p>
      </div>
      <Marquee items={allTechnologies} />
    </div>

    <Manifesto />
    <About />
    <Work />
    <Capabilities />
    <Journey />
    <Now />
    <Writing />
    <Contact />
  </main>

  <Footer />
</BaseLayout>
